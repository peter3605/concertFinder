# Spotify OAuth client ID (developer.spotify.com/dashboard).
SPOTIFY_CLIENT_ID=

# OAuth callback. localhost is rejected by Spotify; use the literal IP for dev.
SPOTIFY_REDIRECT_URI=https://127.0.0.1:3000/api/auth/callback

# Ticketmaster Discovery API key (developer.ticketmaster.com).
TICKETMASTER_API_KEY=

# Any string identifying your traffic to Bandsintown.
BANDSINTOWN_APP_ID=concertfinder-dev

# Postgres connection string. Matches the db service in docker-compose.yml.
DATABASE_URL=postgres://concertfinder:concertfinder@localhost:5432/concertfinder?sslmode=disable

# 32 bytes hex-encoded; generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Cookie domain. 127.0.0.1 for local dev (must match Spotify redirect host).
SESSION_COOKIE_DOMAIN=127.0.0.1

# Bind address for the Go API.
LISTEN_ADDR=:8080

# Phase 1 hardcoded location (design §10.1). Defaults are NYC / 50 miles.
USER_LATITUDE=40.7128
USER_LONGITUDE=-74.0060
USER_RADIUS_MILES=50

# --- Phase 2 (small-artist fallback chain, design §5.4) ---

# Set to "1" or "true" to enable Tier A/B fallbacks for high-affinity
# artists that both Ticketmaster and Bandsintown return empty for.
PHASE2_FALLBACKS_ENABLED=false

# Only artists with affinity score >= this threshold escalate to fallbacks.
# 2.0 filters out casual signals; tune based on your affinity distribution.
PHASE2_MIN_SCORE=2.0

# TODO: sign up at https://api.search.brave.com/ and paste key here.
# Without this, Tier B (search → JSON-LD scrape) is unavailable and the
# chain falls through gracefully.
BRAVE_SEARCH_API_KEY=

# TODO: register at https://www.songkick.com/developer and paste key here.
# Without this, the Songkick tier is skipped.
SONGKICK_API_KEY=
